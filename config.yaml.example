camera:
  host: "192.168.1.64"
  username: "admin"
  password: "CHANGEME"
  rtsp_main: "rtsp://admin:CHANGEME@192.168.1.64:554/Streaming/Channels/101"
  rtsp_sub: "rtsp://admin:CHANGEME@192.168.1.64:554/Streaming/Channels/102"

telegram:
  token: "PUT-YOUR-BOT-TOKEN-HERE"
  chat_id: 0              # основний чат (надішли боту /id або /start, візьми ID)
  allowed_chats: []       # додаткові дозволені чати/групи, напр. [-5293721438]
  notify_on_motion: true

capture:
  snapshot_interval: "5m"
  data_dir: "./data"
  motion_clip_seconds: 15

retention:
  max_days: 14         # видаляти файли старші за N днів (0 = без ліміту за віком)
  max_size_gb: 5.0     # тримати сумарний розмір під X ГБ (0 = без ліміту)
  interval: "1h"

server:
  addr: ":8080"
